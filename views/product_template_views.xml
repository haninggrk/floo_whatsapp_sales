<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_view_form_floo_whatsapp_orderable" model="ir.ui.view">
        <field name="name">product.template.form.floo.whatsapp.orderable</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='sale_ok']" position="after">
                <field name="is_whatsapp_orderable"/>
            </xpath>
        </field>
    </record>

    <record id="product_template_view_tree_floo_whatsapp_orderable" model="ir.ui.view">
        <field name="name">product.template.tree.floo.whatsapp.orderable</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='sale_ok']" position="after">
                <field name="is_whatsapp_orderable" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
