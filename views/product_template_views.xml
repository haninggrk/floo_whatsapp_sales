<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_view_form_floo_whatsapp_orderable" model="ir.ui.view">
        <field name="name">product.template.form.floo.whatsapp.orderable</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="is_whatsapp_orderable"/>
            </xpath>
        </field>
    </record>

    <record id="product_template_view_tree_floo_whatsapp_orderable" model="ir.ui.view">
        <field name="name">product.template.list.sellable.floo.whatsapp.orderable</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_list_view_sellable"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="is_whatsapp_orderable" optional="show" readonly="0"/>
            </xpath>
        </field>
    </record>
</odoo>
