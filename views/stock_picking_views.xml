<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_floo_whatsapp_sales" model="ir.ui.view">
        <field name="name">stock.picking.form.floo.whatsapp.sales</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_wa_lock_delivery_date"
                        type="object"
                        string="Lock Delivery Date"
                        class="btn-primary"
                        invisible="picking_type_code != 'outgoing' or wa_delivery_date_locked"/>
                <button name="action_wa_unlock_delivery_date"
                    type="object"
                    string="Unlock Delivery Date"
                    class="btn-secondary"
                    invisible="picking_type_code != 'outgoing' or not wa_delivery_date_locked"/>
            </xpath>

            <xpath expr="//field[@name='scheduled_date']" position="attributes">
                <attribute name="readonly">wa_delivery_date_locked</attribute>
            </xpath>

            <xpath expr="//field[@name='scheduled_date']" position="after">
                <field name="wa_delivery_date_locked" readonly="1"/>
                <span class="text-success ms-2" invisible="not wa_delivery_date_locked">
                    <i class="fa fa-lock"/> Tanggal Terkunci
                </span>
            </xpath>
        </field>
    </record>
</odoo>
